{
	"schemaVersion": 1,
	"id": "quickharvest",
	"version": "${version}",
	"name": "Quick Harvest",
	"description": "Right-click fully grown crops to harvest and auto-replant them. Supports vanilla and most modded crops out of the box. Configurable hoe requirement, durability cost, XP drops, and per-block allow/deny lists.",
	"authors": [
		"KingxIon!"
	],
	"contact": {
		"homepage": "https://ionwiki.netlify.app/",
		"sources": "https://github.com/christopherbarnessmith-hub/quickharvest_26.x"
	},
	"license": "CC0-1.0",
	"icon": "assets/quickharvest/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.kingxion.quickharvest.QuickHarvest"
		],
		"client": [
			"com.kingxion.quickharvest.client.QuickHarvestClient"
		]
	},
	"mixins": [
		"quickharvest.mixins.json",
		{
			"config": "quickharvest.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
	}
}